# ─── AI Providers ──────────────────────────────────────────────────────
# At least ONE provider key must be set. If both are set, the system
# will use the primary first and fall back to the other if it fails.

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Which provider to try first ("anthropic" or "openai")
AI_PROVIDER_PRIMARY=anthropic

# Which provider to fall back to if primary fails
# Leave blank to disable fallback
AI_PROVIDER_FALLBACK=openai


# ─── Encryption ────────────────────────────────────────────────────────
# Used to encrypt stored credentials in SQLite.
# Leave blank on first run — the app will generate one and write it back.
ENCRYPTION_KEY=


# ─── Server ────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# IANA timezone for the cron scheduler (e.g. "America/Toronto", "UTC", "Asia/Kolkata").
# Defaults to the system timezone if blank.
SCHEDULER_TZ=


# ─── Browser ───────────────────────────────────────────────────────────
# "headed" shows the browser window (recommended for demos)
# "headless" runs invisibly
BROWSER_MODE=headed

# "msedge" for Microsoft Edge, "chromium" for default Chromium
BROWSER_CHANNEL=msedge


# ─── Email alerts (Resend) ────────────────────────────────────────────
# Argus emails you when a workflow run fails its health rules ("alert")
# or hits a system error (timeout, auth failure, etc).
# Leave RESEND_API_KEY blank to disable email entirely — runs still record
# to the dashboard, just without email.
#
# Get a free Resend key at https://resend.com (100 emails/day on free tier).
# The "from" address must use a domain you've verified in Resend, OR you can
# use Resend's onboarding sender for testing: onboarding@resend.dev
RESEND_API_KEY=
NOTIFY_EMAIL_FROM=onboarding@resend.dev
NOTIFY_EMAIL_TO=

# Optional: a friendly "from" name shown in the email client.
NOTIFY_EMAIL_FROM_NAME=Argus AI

# Public URL of this Argus instance (used to build clickable links in emails).
# Leave blank to send links pointing at localhost.
PUBLIC_BASE_URL=
