# ─── AI Providers ──────────────────────────────────────────────────────
# At least ONE provider key must be set. If both are set, the system
# will use the primary first and fall back to the other if it fails.

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Which provider to try first ("anthropic" or "openai")
AI_PROVIDER_PRIMARY=anthropic

# Which provider to fall back to if primary fails
# Leave blank to disable fallback
AI_PROVIDER_FALLBACK=openai


# ─── Encryption ────────────────────────────────────────────────────────
# Used to encrypt stored credentials in SQLite.
# Leave blank on first run — the app will generate one and write it back.
ENCRYPTION_KEY=


# ─── Server ────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# IANA timezone for the cron scheduler (e.g. "America/Toronto", "UTC", "Asia/Kolkata").
# Defaults to the system timezone if blank.
SCHEDULER_TZ=


# ─── Browser ───────────────────────────────────────────────────────────
# "headed" shows the browser window (recommended for demos)
# "headless" runs invisibly
BROWSER_MODE=headed

# "msedge" for Microsoft Edge, "chromium" for default Chromium
BROWSER_CHANNEL=msedge
