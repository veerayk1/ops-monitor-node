# Argus AI — System Architecture
#
# This diagram is designed for non-technical leadership review.
# Labels favor business language; technical detail is in brackets.
#
# Render with:
#   d2 -t 200 --layout=elk docs/architecture.d2 docs/architecture.svg
#   sed -i.bak 's|preserveAspectRatio="xMinYMin meet" viewBox="0 0 \([0-9]*\) \([0-9]*\)"|width="\1" height="\2" preserveAspectRatio="xMinYMin meet" viewBox="0 0 \1 \2"|' docs/architecture.svg
#   rm docs/architecture.svg.bak

direction: down

vars: {
  d2-config: {
    theme-id: 200
    pad: 32
    sketch: false
  }
}

# ─── Operator (the person) ─────────────────────────────────────────
operator: "Operator" {
  shape: person
  style: {
    fill: "#1e1e26"
    stroke: "#a78bfa"
    stroke-width: 2
    font-color: "#e0e7ff"
    font-size: 18
    bold: true
  }
}

# ─── Argus AI Platform ─────────────────────────────────────────────
argus: "Argus AI Platform" {
  style: {
    fill: "#0f172a"
    stroke: "#6366f1"
    stroke-width: 3
    font-color: "#e0e7ff"
    font-size: 24
    bold: true
    border-radius: 18
  }

  # Layer 1: What the operator sees and interacts with
  ui: "Web Dashboard\n(single pane of glass for all workflows)" {
    style: {
      fill: "#1e3a8a"
      stroke: "#60a5fa"
      stroke-width: 2
      font-color: "#dbeafe"
      font-size: 16
      bold: true
      border-radius: 10
    }
  }

  # Layer 2: The brain
  engine: "Monitoring Engine" {
    style: {
      fill: "#3a1f0d"
      stroke: "#fb923c"
      stroke-width: 2
      font-color: "#fed7aa"
      font-size: 17
      bold: true
      border-radius: 12
    }

    scheduler: "Scheduler\n(runs on schedule — for example,\nevery hour during business days)" {
      style.fill: "#7c2d12"
      style.stroke: "#fb923c"
      style.font-color: "#fed7aa"
      style.border-radius: 8
      style.font-size: 13
    }

    rule_engine: "Health Rule Engine\n(checks the live numbers against\nthe team's defined thresholds)" {
      style.fill: "#7c2d12"
      style.stroke: "#fb923c"
      style.font-color: "#fed7aa"
      style.border-radius: 8
      style.font-size: 13
    }

    confirm: "Wait-and-Confirm Safety Net\n(re-checks failing rules to avoid\nalerting on transient blips)" {
      style.fill: "#7c2d12"
      style.stroke: "#fb923c"
      style.font-color: "#fed7aa"
      style.border-radius: 8
      style.font-size: 13
    }
  }

  # Layer 3: How we connect to the systems being monitored
  connectors: "Data Source Connectors\n(pluggable per workflow — each workflow picks one)" {
    style: {
      fill: "#2e1065"
      stroke: "#a78bfa"
      stroke-width: 2
      font-color: "#e9d5ff"
      font-size: 16
      bold: true
      border-radius: 12
    }

    option1: "Option 1 — Direct API\n(active for our RabbitMQ workflows)\n\nSpeed: ~50 ms per check\nCost: free\nReliability: deterministic\n[HTTP + Basic Auth]" {
      style.fill: "#4c1d95"
      style.stroke: "#a78bfa"
      style.font-color: "#fff"
      style.font-size: 13
      style.bold: true
      style.border-radius: 8
    }

    option2: "Option 2 — Universal Adapter (AI Vision)\n(strategic fallback — can monitor anything\nwith a web UI, even systems without an API)\n\nSpeed: ~10–30 seconds per check\nCost: small fraction of a cent per check\nReliability: AI-augmented, screenshot-based\n[Playwright + Claude or GPT vision]" {
      style.fill: "#4c1d95"
      style.stroke: "#a78bfa"
      style.font-color: "#fff"
      style.font-size: 13
      style.bold: true
      style.border-radius: 8
    }
  }

  # Layer 4: Storage
  data: "Audit & Storage" {
    style: {
      fill: "#0c2e1f"
      stroke: "#34d399"
      stroke-width: 2
      font-color: "#d1fae5"
      font-size: 16
      bold: true
      border-radius: 12
    }

    sqlite: "Local Database\n(every run recorded forever\nfor full audit trail)\n[SQLite + WAL mode]" {
      shape: cylinder
      style.fill: "#064e3b"
      style.stroke: "#34d399"
      style.font-color: "#d1fae5"
      style.font-size: 13
    }
  }

  # Layer 5: Alerts
  alerts: "Alert System\n(notifies operators when something is wrong\nor when the platform itself hasn't run recently)" {
    style: {
      fill: "#3f2e1f"
      stroke: "#fbbf24"
      stroke-width: 2
      font-color: "#fde68a"
      font-size: 15
      bold: true
      border-radius: 10
    }
  }
}

# ─── External Systems ──────────────────────────────────────────────
rmq: "RabbitMQ\nMessage Queue Cluster\n(the system being monitored)" {
  shape: cloud
  style: {
    fill: "#3f1d1d"
    stroke: "#f87171"
    stroke-width: 2
    font-color: "#fecaca"
    font-size: 14
    bold: true
  }
}

claude_api: "Anthropic Claude\nAI service\n(used in two optional places —\nsee labels on connecting lines)" {
  shape: cloud
  style: {
    fill: "#1f1f3f"
    stroke: "#a78bfa"
    stroke-width: 2
    font-color: "#e9d5ff"
    font-size: 14
    bold: true
  }
}

email_service: "Email Delivery\n[Resend]" {
  shape: cloud
  style: {
    fill: "#3f2e1f"
    stroke: "#fbbf24"
    stroke-width: 2
    font-color: "#fde68a"
    font-size: 14
    bold: true
  }
}

inbox: "Operator Inbox" {
  shape: rectangle
  style: {
    fill: "#1e1e26"
    stroke: "#fbbf24"
    stroke-width: 2
    font-color: "#fde68a"
    font-size: 14
    bold: true
    border-radius: 8
  }
}

# ─── Connections ───────────────────────────────────────────────────

# Operator interacts with the dashboard
operator -> argus.ui: "Reviews health, writes rules,\nresponds to alerts" {
  style.stroke: "#a78bfa"
  style.stroke-width: 2
  style.font-size: 12
}

# Dashboard reads/writes to storage via the engine
argus.ui -> argus.engine: "Configures workflows,\ntriggers manual runs" {
  style.stroke: "#60a5fa"
  style.font-size: 12
}
argus.ui -> argus.data.sqlite: "Reads history\nto display dashboard" {
  style.stroke: "#60a5fa"
  style.stroke-dash: 4
  style.font-size: 12
}

# AI Rule Writer — only when operator clicks "Convert to rules"
argus.ui -> claude_api: "OPTIONAL: Converts plain English to rules\n(only when operator clicks Convert button —\nnot during scheduled monitoring)" {
  style.stroke: "#c4b5fd"
  style.stroke-width: 2
  style.font-color: "#c4b5fd"
  style.font-size: 12
  style.bold: true
}

# Monitoring engine runs the checks
argus.engine.scheduler -> argus.engine.rule_engine: "Fires on cron" {
  style.stroke: "#fb923c"
  style.font-size: 12
}

argus.engine.rule_engine -> argus.connectors: "Asks for live\nqueue numbers" {
  style.stroke: "#fb923c"
  style.font-size: 12
}

# The two data-source options
argus.connectors.option1 -> rmq: "GET /api/queues\n(direct, fast, free)" {
  style.stroke: "#f87171"
  style.stroke-width: 2
  style.font-size: 12
}

argus.connectors.option2 -> rmq: "Logs in via browser,\ntakes a screenshot" {
  style.stroke: "#f87171"
  style.stroke-dash: 4
  style.font-size: 12
}

argus.connectors.option2 -> claude_api: "AI reads the screenshot\nto extract queue data" {
  style.stroke: "#a78bfa"
  style.stroke-dash: 4
  style.font-size: 12
}

# Confirm step on failure
argus.engine.rule_engine -> argus.engine.confirm: "If a rule fails,\nwait then re-check" {
  style.stroke: "#fb923c"
  style.font-size: 12
}

# Persist verdict
argus.engine.rule_engine -> argus.data.sqlite: "Records verdict +\nobserved numbers" {
  style.stroke: "#34d399"
  style.stroke-width: 2
  style.font-size: 12
}

# Alerts on failure
argus.engine.confirm -> argus.alerts: "Trigger alert\nif still failing" {
  style.stroke: "#fbbf24"
  style.stroke-width: 2
  style.font-size: 12
  style.bold: true
}

argus.alerts -> email_service: "Send HTML email" {
  style.stroke: "#fbbf24"
  style.font-size: 12
}

email_service -> inbox: "Delivers" {
  style.stroke: "#fbbf24"
  style.font-size: 12
}
